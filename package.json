{
  "name": "timesheet-tracker",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first desktop timesheet tracker with an always-on-top overlay.",
  "main": "dist/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
