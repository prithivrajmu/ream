{
  "name": "ream",
  "version": "0.1.0",
  "private": true,
  "description": "Ream is a local-first desktop task time tracker with notes and an always-on-top overlay.",
  "main": "out/main/index.js",
  "desktopName": "ream",
  "homepage": "https://github.com/prithivrajmu/ream",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:linux": "electron-vite dev -- --no-sandbox",
    "lint": "eslint .",
    "pack": "npm run build && electron-builder --dir",
    "dist:mac": "npm run build && electron-builder --mac --x64 --arm64",
    "dist:mac:unsigned": "CSC_IDENTITY_AUTO_DISCOVERY=false npm run dist:mac",
    "dist:linux": "npm run build && electron-builder --linux AppImage deb tar.gz",
    "dist:linux:dir": "npm run build && electron-builder --linux --dir",
    "release:checksums": "node scripts/generate-checksums.mjs",
    "release:homebrew": "node scripts/generate-homebrew-formula.mjs",
    "release:apt": "node scripts/generate-apt-repo.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "dexie": "^4.4.4",
    "electron-vite": "^5.0.0",
    "fake-indexeddb": "^6.2.5",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@iannuttall/ralph": "^0.1.3",
    "@types/node": "^25.0.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "electron": "^40.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^7.3.6",
    "vitest": "^4.0.15"
  },
  "build": {
    "appId": "com.prithiv.ream",
    "productName": "Ream",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**",
      "package.json"
    ],
    "asar": true,
    "icon": "build/icon.png",
    "extraResources": [
      {
        "from": "build/icons/ream-icon.png",
        "to": "ream-icon.png"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "tar.gz"
      ],
      "category": "Office",
      "icon": "build/icons",
      "syncDesktopName": true,
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "maintainer": "Prithiv Raj <prithivrajmu@gmail.com>",
      "synopsis": "Task time tracker with notes and projects",
      "description": "Ream is a local-first desktop task time tracker with notes, projects, and an always-on-top overlay."
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  },
  "author": {
    "name": "Prithiv Raj",
    "email": "prithivrajmu@gmail.com"
  }
}
